# Public values: safe to expose in browser
NEXT_PUBLIC_API_URL=https://your-render-backend.onrender.com
# GA4 Measurement ID (example: G-66H7PS2KWR)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GOOGLE_ADS_ID=AW-123456789
NEXT_PUBLIC_GOOGLE_ADS_LEAD_LABEL=AbCdEfGhIjKlMnOpQrSt
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=google-site-verification-token

# Server-only values: never use NEXT_PUBLIC_ prefix
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-a-long-random-password
ADMIN_AUTH_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
